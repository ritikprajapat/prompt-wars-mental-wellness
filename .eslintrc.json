{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "no-console": "warn",
    "prefer-const": "warn",
    "eqeqeq": ["warn", "smart"],
    "consistent-return": "warn",
    "no-unused-vars": "off"
  },
  "overrides": [
    {
      "files": ["src/lib/logger.ts"],
      "rules": { "no-console": "off" }
    },
    {
      "files": ["src/__tests__/**/*"],
      "rules": { "no-console": "off" }
    }
  ],
  "ignorePatterns": [".next/", "node_modules/", "coverage/"]
}
